# === Server ===
SERVER_PORT=8000

# === Database (PostgreSQL) ===
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/traffic_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# === Flyway ===
# SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# === Redis ===
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6380

# === Cache ===
APP_REDIS_CACHE_ENABLED=true
APP_CACHE_TTL_SECONDS=30

# === Database Mirror ===
APP_DB_PRIMARY=postgres
APP_DB_MIRROR_MYSQL_URL=
APP_DB_MIRROR_MYSQL_USERNAME=
APP_DB_MIRROR_MYSQL_PASSWORD=
APP_DB_MIRROR_POSTGRES_URL=
APP_DB_MIRROR_POSTGRES_USERNAME=
APP_DB_MIRROR_POSTGRES_PASSWORD=

# === App ===
APP_ENV=development
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
APP_WS_ALLOW_QUERY_TOKEN=true

# === JWT ===
JWT_SECRET=change-this-dev-secret-change-this-dev-secret
ACCESS_TOKEN_EXPIRE_DAYS=7

# === Init Admin ===
INIT_ADMIN=false
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# === MaaS ===
APP_MAAS_DEFAULT_CLIENT_NAME=default-dev-client
APP_MAAS_DEFAULT_API_KEY=dev-maas-key-change-me
