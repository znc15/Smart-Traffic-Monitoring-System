# backend runtime example
#
# If you start database / mysql / redis through the repo root docker-compose,
# the following defaults match that stack.

# --- Server ---
SERVER_PORT=8000
APP_ENV=development
BASE_URL_API=http://localhost:8000

# --- Database (PostgreSQL primary) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/transportation_system
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=odoo
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# --- Redis ---
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6380
APP_REDIS_CACHE_ENABLED=true
APP_CACHE_TTL_SECONDS=10

# --- Security ---
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
APP_WS_ALLOW_QUERY_TOKEN=true
JWT_SECRET=change-this-dev-secret-change-this-dev-secret
ACCESS_TOKEN_EXPIRE_DAYS=7

# --- Init Admin ---
INIT_ADMIN=false
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# --- MaaS ---
APP_MAAS_DEFAULT_CLIENT_NAME=default-dev-client
APP_MAAS_DEFAULT_API_KEY=dev-maas-key-change-me

# --- Seed data ---
TRAFFIC_ROADS=陈兴道路,陈富路,阮惠路,黎利路,阮廌路

# --- Database mirror / gray release ---
APP_DB_PRIMARY=postgres
APP_DB_MIRROR_WRITE=false

APP_DB_MIRROR_MYSQL_ENABLED=false
APP_DB_MIRROR_MYSQL_URL=jdbc:mysql://localhost:3307/transportation_system_mysql?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
APP_DB_MIRROR_MYSQL_USERNAME=traffic
APP_DB_MIRROR_MYSQL_PASSWORD=traffic

APP_DB_MIRROR_POSTGRES_ENABLED=false
APP_DB_MIRROR_POSTGRES_URL=jdbc:postgresql://localhost:5433/transportation_system
APP_DB_MIRROR_POSTGRES_USERNAME=postgres
APP_DB_MIRROR_POSTGRES_PASSWORD=odoo
