# Frontend build-time variables
#
# These variables are read by Vite during `pnpm build`.
# Changing them requires rebuilding the frontend assets or Docker image.
#
# If you build the main site through the repo root docker-compose, prefer editing:
# - GATEWAY_PUBLIC_BASE
# - BACKEND_PUBLIC_HTTP_BASE
# - BACKEND_PUBLIC_WS_BASE
# in the root `.env`.

# Leave empty when frontend / API / WebSocket are served through the same gateway.
VITE_API_HTTP_BASE=
VITE_API_WS_BASE=

# Optional: AMap Web JS API Key for GIS map page.
# This is a build-time fallback. Admins can override it later in
# 系统管理 -> 站点设置 without rebuilding the frontend.
VITE_AMAP_KEY=your_amap_web_js_key
