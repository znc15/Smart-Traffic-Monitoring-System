# edge runtime example

# --- Runtime ---
MODE=sim
CAMERA_URL=
ROAD_NAME=示例路段-Edge01
MODEL=yolov8n.pt
CONF=0.35
OPENVINO=true
NO_BROWSER=true
HOST=0.0.0.0
PUBLIC_HOST=
PORT=8000

# --- Performance tuning ---
FRAME_SKIP=2
IMGSZ=320
QUANTIZE=none
JPEG_QUALITY=80
MAX_MJPEG_CLIENTS=5
UVICORN_WORKERS=1

# --- Tracking ---
TRACKER_BACKEND=bytetrack
TRACKER_STRICT=false
TRACKER_CFG=bytetrack.yaml

# --- Telemetry / auth ---
EDGE_NODE_ID=edge-01
EDGE_API_KEY=
BACKEND_TELEMETRY_URL=
TELEMETRY_INTERVAL_SEC=3

# --- Traffic analysis ---
ANALYSIS_ROI=0.05,0.25,0.95,0.95
LANE_SPLIT_RATIOS=0.33,0.66
SPEED_METERS_PER_PIXEL=0.08
PARKING_STATIONARY_SECONDS=8
WRONG_WAY_MIN_TRACK_POINTS=4
