# Root docker compose runtime variables
#
# Copy to `.env` before running:
#   cp .env.example .env
#   docker compose up --build -d
#
# This file is now the main entry for:
# - backend runtime config
# - frontend build-time API / WS addresses
#
# Main site one-click startup covers:
# gateway + frontend + backend + database + mysql + redis
# edge remains an independent deployment.

# --- Public addresses ---
# Browser entry for the main site (served by gateway)
GATEWAY_PUBLIC_BASE=http://localhost:5173

# Frontend builds these two addresses into the final dist bundle.
# Use backend public IP / domain here when frontend and backend are on different hosts.
BACKEND_PUBLIC_HTTP_BASE=http://localhost:8000
BACKEND_PUBLIC_WS_BASE=ws://localhost:8000

# Example for split-IP deployment:
# GATEWAY_PUBLIC_BASE=http://192.168.1.10:5173
# BACKEND_PUBLIC_HTTP_BASE=http://192.168.1.11:8000
# BACKEND_PUBLIC_WS_BASE=ws://192.168.1.11:8000

# --- Database secrets ---
POSTGRES_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
MYSQL_PASSWORD=change-me

# --- Backend security / public access ---
# JWT secret must be at least 32 characters
JWT_SECRET=replace-with-random-32-char-secret
MAAS_API_KEY=replace-with-your-maas-api-key
APP_ENV=production

# Optional overrides. If omitted, docker-compose.yml will default:
# - APP_CORS_ALLOWED_ORIGINS -> GATEWAY_PUBLIC_BASE
# - BASE_URL_API -> BACKEND_PUBLIC_HTTP_BASE
# backend 会自动补齐本地开发常见的 localhost <-> 127.0.0.1 别名；
# 如果你用的是自定义域名 / 局域网 IP，请显式把实际浏览器 origin 填进来。
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_WS_ALLOW_QUERY_TOKEN=false

# Public API base used by backend-generated links or external integrations.
# BASE_URL_API=http://localhost:8000

# --- Frontend build-time config ---
# When using root docker compose, frontend reads backend addresses from
# BACKEND_PUBLIC_HTTP_BASE / BACKEND_PUBLIC_WS_BASE automatically.
# `VITE_AMAP_KEY` is a deployment fallback. Admins can override it later in
# 系统管理 -> 站点设置 without rebuilding the frontend.
VITE_AMAP_KEY=your_amap_web_js_key
VITE_AMAP_SECURITY_JS_CODE=
VITE_AMAP_SERVICE_HOST=

# --- Backend app defaults ---
APP_MAAS_DEFAULT_CLIENT_NAME=default-dev-client
TRAFFIC_ROADS=陈兴道路,陈富路,阮惠路,黎利路,阮廌路

# --- Optional init admin ---
INIT_ADMIN=false
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# --- Optional database/runtime overrides ---
SERVER_PORT=8000
ACCESS_TOKEN_EXPIRE_DAYS=7
APP_DB_PRIMARY=postgres
APP_DB_MIRROR_WRITE=false
APP_DB_MIRROR_MYSQL_ENABLED=false
APP_DB_MIRROR_POSTGRES_ENABLED=false
APP_REDIS_CACHE_ENABLED=true
APP_CACHE_TTL_SECONDS=10

# --- Optional datasource overrides ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://database:5432/transportation_system
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=
# SPRING_FLYWAY_LOCATIONS=classpath:db/migration
# SPRING_REDIS_HOST=redis
# SPRING_REDIS_PORT=6379

# --- Optional mirror datasource overrides ---
# APP_DB_MIRROR_MYSQL_URL=jdbc:mysql://mysql:3306/transportation_system_mysql?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
# APP_DB_MIRROR_MYSQL_USERNAME=traffic
# APP_DB_MIRROR_MYSQL_PASSWORD=
# APP_DB_MIRROR_POSTGRES_URL=jdbc:postgresql://database:5432/transportation_system
# APP_DB_MIRROR_POSTGRES_USERNAME=postgres
# APP_DB_MIRROR_POSTGRES_PASSWORD=
