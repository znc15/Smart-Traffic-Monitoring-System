# Root docker compose runtime variables
#
# Copy to `.env` before running:
#   cp .env.example .env
#   docker compose up --build -d
#
# This file is now the main entry for:
# - backend runtime config
# - frontend build-time API / WS addresses
# - edge runtime config when using root docker compose
#
# Main site one-click startup covers:
# gateway + frontend + backend + edge-node + database + redis

# --- Public addresses ---
# Browser entry for the main site (served by gateway)
GATEWAY_PUBLIC_BASE=http://localhost:5173

# Frontend builds these two addresses into the final dist bundle.
# Use backend public IP / domain here when frontend and backend are on different hosts.
BACKEND_PUBLIC_HTTP_BASE=http://localhost:8000
BACKEND_PUBLIC_WS_BASE=ws://localhost:8000

# Example for split-IP deployment:
# GATEWAY_PUBLIC_BASE=http://192.168.1.10:5173
# BACKEND_PUBLIC_HTTP_BASE=http://192.168.1.11:8000
# BACKEND_PUBLIC_WS_BASE=ws://192.168.1.11:8000

# --- Database secrets ---
MYSQL_ROOT_PASSWORD=traffic123
MYSQL_PASSWORD=traffic123

# --- Backend security / public access ---
# JWT secret must be at least 32 characters
JWT_SECRET=replace-with-random-32-char-secret
MAAS_API_KEY=replace-with-your-maas-api-key
APP_ENV=production

# Optional overrides. If omitted, docker-compose.yml will default:
# - APP_CORS_ALLOWED_ORIGINS -> GATEWAY_PUBLIC_BASE
# - BASE_URL_API -> BACKEND_PUBLIC_HTTP_BASE
# backend 会自动补齐本地开发常见的 localhost <-> 127.0.0.1 别名；
# 如果你用的是自定义域名 / 局域网 IP，请显式把实际浏览器 origin 填进来。
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_WS_ALLOW_QUERY_TOKEN=false

# Public API base used by backend-generated links or external integrations.
# BASE_URL_API=http://localhost:8000

# --- Frontend build-time config ---
# When using root docker compose, frontend reads backend addresses from
# BACKEND_PUBLIC_HTTP_BASE / BACKEND_PUBLIC_WS_BASE automatically.
# `VITE_AMAP_KEY` is a deployment fallback. Admins can override it later in
# 节点配置管理 → 站点设置 without rebuilding the frontend.
VITE_AMAP_KEY=your_amap_web_js_key
VITE_AMAP_SECURITY_JS_CODE=
VITE_AMAP_SERVICE_HOST=

# --- Backend app defaults ---
APP_MAAS_DEFAULT_CLIENT_NAME=default-dev-client
TRAFFIC_ROADS=陈兴道路,陈富路,阮惠路,黎利路,阮廌路

# --- Edge node runtime config ---
# Root docker compose exposes the edge container on localhost:9000 by default
# because backend already uses host port 8000.
EDGE_PUBLIC_PORT=9000
EDGE_PYTHON_BASE_IMAGE=python:3.11-slim
EDGE_MODE=sim
EDGE_CAMERA_URL=
EDGE_ROAD_NAME=示例路段-Edge01
EDGE_MODEL=yolov8n.pt
EDGE_CONF=0.3
EDGE_OPENVINO=true
EDGE_NO_BROWSER=true
EDGE_HOST=0.0.0.0
EDGE_PUBLIC_HOST=

# Weak-CPU defaults for demo / industrial PCs.
EDGE_FRAME_SKIP=4
EDGE_IMGSZ=160
EDGE_QUANTIZE=int8
EDGE_JPEG_QUALITY=50
EDGE_MAX_MJPEG_CLIENTS=1
EDGE_UVICORN_WORKERS=1
EDGE_OMP_NUM_THREADS=2
EDGE_OPENVINO_THREADING=SEQ

# Tracking / traffic analysis.
EDGE_TRACKER_BACKEND=bytetrack
EDGE_TRACKER_STRICT=false
EDGE_TRACKER_CFG=bytetrack.yaml
EDGE_ANALYSIS_ROI=0.05,0.25,0.95,0.95
EDGE_LANE_SPLIT_RATIOS=0.33,0.66
EDGE_SPEED_METERS_PER_PIXEL=0.08
EDGE_PARKING_STATIONARY_SECONDS=8
EDGE_WRONG_WAY_MIN_TRACK_POINTS=4

# Edge auth / telemetry. To enable active telemetry, configure a matching
# camera edge_node_id + node_api_key in the admin UI, then set:
# EDGE_BACKEND_TELEMETRY_URL=http://backend:8000/api/v1/edge/telemetry
EDGE_NODE_ID=edge-01
EDGE_API_KEY=
EDGE_BACKEND_TELEMETRY_URL=
EDGE_TELEMETRY_INTERVAL_SEC=3

# Optional Docker resource limits for edge-node.
EDGE_CPU_LIMIT=2.0
EDGE_MEMORY_LIMIT=1.5G
EDGE_CPU_RESERVATION=0.5
EDGE_MEMORY_RESERVATION=256M

# --- Optional init admin ---
INIT_ADMIN=false
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# --- Optional database/runtime overrides ---
SERVER_PORT=8000
ACCESS_TOKEN_EXPIRE_DAYS=7
APP_REDIS_CACHE_ENABLED=true
APP_CACHE_TTL_SECONDS=10

# --- Optional datasource overrides ---
# SPRING_DATASOURCE_URL=jdbc:mysql://database:3306/transportation_system?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=traffic
# SPRING_DATASOURCE_PASSWORD=
# SPRING_FLYWAY_LOCATIONS=classpath:db/migration
# SPRING_REDIS_HOST=redis
# SPRING_REDIS_PORT=6379
