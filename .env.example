# ============================================================
# Smart Traffic Monitoring System — Environment Variables
# ============================================================
# Copy this file to .env and fill in production values.
# For local development, docker compose up works without .env
# (all variables have safe defaults in docker-compose.yml).
# ============================================================

# ---------- Database ----------
POSTGRES_PASSWORD=your-strong-password
MYSQL_ROOT_PASSWORD=your-strong-password
MYSQL_PASSWORD=your-strong-password

# ---------- Backend ----------
# Must be at least 32 characters for HMAC-SHA256
JWT_SECRET=your-random-secret-at-least-32-chars
MAAS_API_KEY=your-api-key

# ---------- Optional ----------
# APP_CORS_ALLOWED_ORIGINS=https://your-domain.com
# SPRING_DATASOURCE_URL=jdbc:postgresql://database:5432/transportation_system
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=  (defaults to POSTGRES_PASSWORD)
